{
  "version": "0.1.9",
  "project": "Noon Sales Ops Copilot",
  "completionPolicy": {
    "requiredPassRate": 100,
    "reportPath": "reports/evaluation-report.md",
    "developmentCompleteOnlyWhenAllPassed": true
  },
  "cases": [
    {
      "id": "VERSION-001",
      "category": "release_hygiene",
      "title": "Package, manifest, evaluation set, and changelog latest version stay aligned",
      "type": "version_alignment",
      "version": "0.1.9"
    },
    {
      "id": "PRD-001",
      "category": "prd_traceability",
      "title": "PRD is stored as Markdown and includes evaluation policy",
      "type": "file_contains",
      "file": "docs/PRD.md",
      "contains": [
        "# Noon Sales Ops Copilot Chrome 插件 PRD v0.1",
        "Evaluation Policy",
        "100% 通过"
      ]
    },
    {
      "id": "DEV-001",
      "category": "development_standard",
      "title": "Development rules require PRD-first and full evaluation",
      "type": "file_contains",
      "file": "docs/DEVELOPMENT_RULES.md",
      "contains": [
        "PRD 先行",
        "冲突先指出",
        "npm run evaluate"
      ]
    },
    {
      "id": "MV3-001",
      "category": "extension_manifest",
      "title": "Chrome extension uses Manifest V3 and minimal active tab injection",
      "type": "manifest",
      "expected": {
        "manifest_version": 3,
        "permissions": [
          "activeTab",
          "scripting"
        ]
      }
    },
    {
      "id": "HOST-001",
      "category": "domain_support",
      "title": "Noon domains are supported and non-noon domains are rejected",
      "type": "host_support",
      "accepted": [
        "noon.com",
        "www.noon.com",
        "www.noon.ae",
        "www.noon.sa"
      ],
      "rejected": [
        "example.com",
        "notnoon.com"
      ]
    },
    {
      "id": "SALES-001",
      "category": "sales_parser",
      "title": "Sales parser supports common visible sales formats",
      "type": "sales_parser",
      "samples": [
        {
          "input": "100 sold",
          "expected": 100
        },
        {
          "input": "100+ sold",
          "expected": 100
        },
        {
          "input": "1.2K sold",
          "expected": 1200
        },
        {
          "input": "10k+",
          "expected": 10000
        },
        {
          "input": "860+ sold recently",
          "expected": 860
        },
        {
          "input": "",
          "expected": null
        }
      ]
    },
    {
      "id": "RATINGS-001",
      "category": "ratings_parser",
      "title": "Ratings count from noon list/detail pages can be used as sales signal fallback",
      "type": "review_parser",
      "samples": [
        {
          "input": "40 Ratings",
          "expected": 40
        },
        {
          "input": "3.4 (62)",
          "expected": 62
        },
        {
          "input": "4.7 23 AED 129",
          "expected": 23
        },
        {
          "input": "4.7 ★★★★★ 23 | Best Seller",
          "expected": 23
        }
      ]
    },
    {
      "id": "SIGNAL-001",
      "category": "sales_signal",
      "title": "Sales signal prefers sold recently and falls back to ratings",
      "type": "sales_signal",
      "samples": [
        {
          "product": {
            "salesCount": 860,
            "salesText": "860+ sold recently",
            "reviewCount": 40
          },
          "expected": {
            "count": 860,
            "text": "860+ sold recently",
            "source": "sold"
          }
        },
        {
          "product": {
            "reviewCount": 40
          },
          "expected": {
            "count": 40,
            "text": "40 Ratings",
            "source": "ratings"
          }
        }
      ]
    },
    {
      "id": "PRICE-001",
      "category": "price_parser",
      "title": "Price parser extracts amount and currency",
      "type": "price_parser",
      "samples": [
        {
          "input": "AED 129.50",
          "expected": {
            "price": 129.5,
            "currency": "AED"
          }
        },
        {
          "input": "SAR 1,299",
          "expected": {
            "price": 1299,
            "currency": "SAR"
          }
        }
      ]
    },
    {
      "id": "SORT-000",
      "category": "sorting",
      "title": "Default sorting uses Ratings heat instead of sales volume",
      "type": "sort",
      "products": [
        {
          "id": "a",
          "title": "A",
          "reviewCount": 40,
          "salesSignalCount": 860,
          "pagePosition": 1
        },
        {
          "id": "b",
          "title": "B",
          "reviewCount": 62,
          "salesSignalCount": 100,
          "pagePosition": 2
        },
        {
          "id": "c",
          "title": "C",
          "salesSignalCount": 1200,
          "pagePosition": 3
        }
      ],
      "expectedOrder": [
        "b",
        "a",
        "c"
      ]
    },
    {
      "id": "SORT-001",
      "category": "sorting",
      "title": "Default sales sorting puts missing sales last",
      "type": "sort",
      "mode": "sales_desc",
      "products": [
        {
          "id": "a",
          "title": "A",
          "pagePosition": 1
        },
        {
          "id": "b",
          "title": "B",
          "salesSignalCount": 20,
          "pagePosition": 2
        },
        {
          "id": "c",
          "title": "C",
          "salesSignalCount": 120,
          "pagePosition": 3
        }
      ],
      "expectedOrder": [
        "c",
        "b",
        "a"
      ]
    },
    {
      "id": "EXPORT-001",
      "category": "export",
      "title": "CSV and table copy exports include stable business columns",
      "type": "export_columns",
      "expectedColumns": [
        "排名",
        "商品名称",
        "销量",
        "销量来源",
        "价格",
        "评分",
        "评论数",
        "商品链接"
      ]
    },
    {
      "id": "DEDUPE-001",
      "category": "extraction",
      "title": "Duplicate product candidates collapse into one product before release",
      "type": "dedupe_products",
      "products": [
        {
          "id": "candidate-1",
          "title": "Dreamhouse Playset Pool Party Doll House",
          "url": "https://www.noon.com/uae-en/dreamhouse-playset-pool-party-doll-house/p/?o=one",
          "price": 129,
          "reviewCount": 23,
          "pagePosition": 1
        },
        {
          "id": "candidate-2",
          "title": "Dreamhouse Playset Pool Party Doll House",
          "url": "https://www.noon.com/uae-en/dreamhouse-playset-pool-party-doll-house/p/?o=two",
          "price": 129,
          "reviewCount": 23,
          "pagePosition": 2
        }
      ],
      "expectedCount": 1
    },
    {
      "id": "FILTER-001",
      "category": "extraction",
      "title": "Merchandising and utility blocks are rejected before sorting",
      "type": "product_filter",
      "samples": [
        {
          "title": "Reject Best Seller utility block",
          "product": {
            "title": "Best Seller",
            "url": "https://www.noon.com/uae-en/best-sellers",
            "price": 10
          },
          "expected": false
        },
        {
          "title": "Accept noon product URL with price and heat",
          "product": {
            "title": "Dreamhouse Playset Pool Party Doll House",
            "url": "https://www.noon.com/uae-en/dreamhouse-playset-pool-party-doll-house/Z779A06B254C62B0273EBZ/p/",
            "price": 129,
            "reviewCount": 23
          },
          "expected": true
        }
      ]
    },
    {
      "id": "READY-001",
      "category": "extraction",
      "title": "Only complete products with usable noon product links can be displayed",
      "type": "display_ready_product",
      "samples": [
        {
          "title": "Reject product candidate without usable link",
          "product": {
            "title": "Dreamhouse Playset Pool Party Doll House",
            "url": "",
            "price": 129,
            "reviewCount": 23
          },
          "expected": false
        },
        {
          "title": "Accept complete product candidate with noon product link",
          "product": {
            "title": "Dreamhouse Playset Pool Party Doll House",
            "url": "https://www.noon.com/uae-en/dreamhouse-playset-pool-party-doll-house/Z779A06B254C62B0273EBZ/p/",
            "price": 129,
            "reviewCount": 23
          },
          "expected": true
        }
      ]
    },
    {
      "id": "METRIC-001",
      "category": "interaction",
      "title": "Product cards highlight the active sorting metric and avoid duplicate secondary indicators",
      "type": "file_contains",
      "file": "src/content.js",
      "contains": [
        "getPrimaryMetric",
        "getSecondaryMetrics",
        "noon-ops-primary",
        "noon-ops-secondary",
        "state.sortMode === \"price_asc\"",
        "state.sortMode === \"sales_desc\"",
        "热度"
      ]
    },
    {
      "id": "LOCATE-001",
      "category": "interaction",
      "title": "Product title click locates the current page item instead of opening a new page",
      "type": "file_contains",
      "file": "src/content.js",
      "contains": [
        "locateProduct",
        "temporarilyRevealPageForLocate",
        "is-locating",
        "inline: \"center\"",
        "scrollIntoView",
        "noon-ops-source-highlight"
      ]
    },
    {
      "id": "AUTO-001",
      "category": "interaction",
      "title": "Panel auto refreshes when URL or page product DOM changes",
      "type": "file_contains",
      "file": "src/content.js",
      "contains": [
        "MutationObserver",
        "patchHistory",
        "scheduleAutoRefresh",
        "renderRefreshStatus",
        "refreshStatus",
        "startLocationPolling",
        "mutationLooksRelevant",
        "minAttempts",
        "calculateRefreshProgress",
        "renderSkeletonList",
        "isDisplayReadyProduct",
        "shouldCommitResult"
      ]
    },
    {
      "id": "INSIGHT-001",
      "category": "insights",
      "title": "No visible sales produces a data gap insight",
      "type": "insight",
      "products": [
        {
          "id": "p1",
          "title": "Product 1",
          "price": 20,
          "rating": 4.5,
          "pagePosition": 1
        }
      ],
      "expectedType": "data_gap"
    },
    {
      "id": "INSIGHT-002",
      "category": "insights",
      "title": "Visible sales produces top seller guidance",
      "type": "insight",
      "products": [
        {
          "id": "p1",
          "title": "Top Product",
          "price": 20,
          "salesCount": 200,
          "rating": 4.4,
          "pagePosition": 1
        },
        {
          "id": "p2",
          "title": "Second Product",
          "price": 18,
          "salesCount": 100,
          "rating": 4.2,
          "pagePosition": 2
        }
      ],
      "expectedType": "top_seller"
    }
  ]
}
